# .env.example — copy to .env and fill in your values
# Never commit .env to git (it is in .gitignore)

# AWS RDS PostGIS connection
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=gisdb
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# MAPC data source (override if the default URL changes)
# Find current URL at: https://data-metroboston.opendata.arcgis.com/ → search "Zoning Atlas"
# MAPC_ZONING_URL=https://data-metroboston.opendata.arcgis.com/datasets/mapc::zoning-atlas.geojson

# Pipeline behaviour
FORCE_DOWNLOAD=false     # Set true to re-download even if cache exists
DRY_RUN=false            # Set true to skip all DB writes (for testing)
